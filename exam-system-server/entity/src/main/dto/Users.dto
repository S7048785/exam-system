export com.yyjy.models.entity.Users
    -> package com.yyjy.models.entity.dto

import jakarta.validation.constraints.Email

input UserLoginInput {
    @Email(message = "邮箱格式错误")
    email
    password: String
}

input UserRegisterInput {
    @Email(message = "邮箱格式错误")
    email
    captcha: String
    realName
    password: String
}
